# ════════════════════════════════════════════════════════════
#  環境變數範本 —— 複製成 .env 後填入你自己的值
#  Windows:  copy .env.example .env
#  macOS/Linux:  cp .env.example .env
#  .env 已被 .gitignore 忽略，不會被 commit。
# ════════════════════════════════════════════════════════════

# ── Gemini AI（AI 分析功能需要）─────────────────────────────
# 申請：https://aistudio.google.com/apikey
# 可填多把 key（逗號分隔），系統會自動輪替避免額度限制
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-3.5-flash

# ── Telegram Bot（選用，預設關閉）───────────────────────────
# 找 @BotFather 建立 bot 取得 token；chat id 可用 @userinfobot 查
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Alpaca 模擬交易（選用，預設關閉）────────────────────────
# 申請 Paper Trading：https://app.alpaca.markets/paper/dashboard
ALPACA_PAPER_KEY=
ALPACA_PAPER_SECRET=

# ── 網頁 AI 功能密碼（保護 /api/news_summary 等耗費 API 的端點）─
WEB_PASSWORD=changeme

# ── 本地 Claude proxy（選用，沒有就留預設）──────────────────
CLAUDE_PROXY_URL=http://localhost:4141

# ── 外部工具路徑（選用，留空會自動從 PATH 尋找）─────────────
# PDF 報告需要 node 套件 md-to-pdf；agy 是 Gemini CLI
MD_TO_PDF_PATH=
AGY_PATH=

# ════════════════════════════════════════════════════════════
#  功能開關 —— true 開啟 / false 關閉
# ════════════════════════════════════════════════════════════
ENABLE_US_MARKET=true
ENABLE_TW_MARKET=true
ENABLE_AI_ANALYSIS=true
ENABLE_TRADING=false
ENABLE_STRATEGY=false
ENABLE_TELEGRAM_BOT=false
ENABLE_BG_WORKERS=true

# ── Web 伺服器 ──────────────────────────────────────────────
WEB_PORT=5000

# ════════════════════════════════════════════════════════════
#  對外導出 —— 把本地服務公開到外網（可抽換）
#  none  = 純本地，只能 localhost 存取（預設）
#  ngrok = 用 ngrok 通道（需填 NGROK_AUTHTOKENS）
# ════════════════════════════════════════════════════════════
TUNNEL_PROVIDER=none
# ngrok authtoken，可填多把（逗號分隔），第一把流量爆會自動換下一把
# 申請：https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKENS=
# 對應的固定 dev domain（與 NGROK_AUTHTOKENS 順序一一對應，沒填就用隨機網址）
# 取得：登入 ngrok dashboard 看 Domains 頁面的 xxx.ngrok-free.dev（每帳號免費 1 條，永久不變）
NGROK_DOMAINS=
